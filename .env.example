# AI Provider — set ONE of the following (Groq is free and recommended)
# Groq (free tier): https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Anthropic Claude (paid): https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# If neither is set, uses claude CLI (only works inside a Claude Code session)

# WordPress
WP_URL=https://yourblog.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=your_wp_application_password

# Pexels API (free images)
PEXELS_API_KEY=your_pexels_api_key_here

# Unsplash API (fallback images)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Site URL (Cloudflare Pages subdomain or custom domain)
SITE_URL=https://yourblog.pages.dev

# Pipeline settings
POSTS_PER_RUN=3
MIN_WORD_COUNT=1500
DEFAULT_CATEGORY_ID=1
DEFAULT_STATUS=draft
